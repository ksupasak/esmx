<%
  # Required locals:
  #   chat_room  — unique room name, e.g. "patient_123_chat"
  #   solution   — current solution name (from session or params)
  #   current_user_id  — logged-in user id
  #   current_username — display name
  chat_room       ||= "general"
  solution        ||= session[:esm].to_s
  current_user_id ||= session[:user].to_s
  current_username||= "User"
%>

<div id="chat-widget-<%= chat_room %>" class="chat-widget panel panel-default" style="display:flex;flex-direction:column;height:480px;border:1px solid #ddd;border-radius:6px;overflow:hidden;">

  <%# ── Header ────────────────────────────────────────────────────── %>
  <div class="chat-header" style="background:#1a73e8;color:#fff;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
    <span><i class="fa fa-comments"></i> <%= chat_room.humanize %></span>
    <span id="chat-status-<%= chat_room %>" style="font-size:11px;opacity:0.8;">
      <i class="fa fa-circle" style="color:#ffd600;"></i> Connecting…
    </span>
  </div>

  <%# ── Messages ──────────────────────────────────────────────────── %>
  <div id="chat-messages-<%= chat_room %>"
       style="flex:1;overflow-y:auto;padding:12px;background:#fafafa;">
    <div class="chat-day-divider" style="text-align:center;color:#999;font-size:11px;margin:8px 0;">
      — <%= Date.today.strftime('%d %b %Y') %> —
    </div>
  </div>

  <%# ── Typing indicator ──────────────────────────────────────────── %>
  <div id="chat-typing-<%= chat_room %>"
       style="padding:2px 12px;font-size:11px;color:#999;min-height:18px;"></div>

  <%# ── Input bar ─────────────────────────────────────────────────── %>
  <div class="chat-input-bar" style="display:flex;border-top:1px solid #e0e0e0;background:#fff;padding:8px;">
    <input  id="chat-input-<%= chat_room %>"
            type="text"
            class="form-control"
            placeholder="Type a message…"
            style="flex:1;margin-right:8px;border-radius:20px;padding:6px 14px;"
            maxlength="1000"
            autocomplete="off" />
    <button id="chat-send-<%= chat_room %>"
            class="btn btn-primary"
            style="border-radius:20px;padding:6px 18px;">
      <i class="fa fa-paper-plane"></i> Send
    </button>
  </div>

</div>

<script>
(function() {
  // ── Config ────────────────────────────────────────────────────────
  var ROOM       = "<%= j chat_room %>";
  var SOLUTION   = "<%= j solution %>";
  var MY_ID      = "<%= j current_user_id %>";
  var MY_NAME    = "<%= j current_username %>";

  // ── DOM refs ──────────────────────────────────────────────────────
  var $box     = $("#chat-messages-" + ROOM);
  var $input   = $("#chat-input-"    + ROOM);
  var $send    = $("#chat-send-"     + ROOM);
  var $status  = $("#chat-status-"   + ROOM);
  var $typing  = $("#chat-typing-"   + ROOM);

  var typingTimer  = null;
  var isTyping     = false;
  var subscription = null;

  // ── Helpers ───────────────────────────────────────────────────────
  function escapeHtml(text) {
    return $("<div>").text(text || "").html();
  }

  function formatTime(ts) {
    var d = ts ? new Date(ts) : new Date();
    return d.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
  }

  function scrollToBottom() {
    $box.scrollTop($box[0].scrollHeight);
  }

  // ── Render a message bubble ───────────────────────────────────────
  function appendMessage(data) {
    var isMine    = String(data.sender_id) === String(MY_ID);
    var senderName= escapeHtml(data.sender_name || "Unknown");
    var text      = escapeHtml(data.message);
    var time      = formatTime(data.time);
    var type      = data.type || "message";

    if (type === "system") {
      $box.append(
        '<div style="text-align:center;margin:6px 0;">' +
          '<span style="font-size:11px;color:#999;background:#f0f0f0;padding:2px 10px;border-radius:10px;">' +
            escapeHtml(data.message) +
          '</span>' +
        '</div>'
      );
      scrollToBottom();
      return;
    }

    var align  = isMine ? "flex-end"  : "flex-start";
    var bg     = isMine ? "#1a73e8"   : "#e8eaed";
    var color  = isMine ? "#ffffff"   : "#202124";
    var label  = isMine ? "" :
      '<div style="font-size:10px;color:#888;margin-bottom:2px;">' + senderName + '</div>';

    $box.append(
      '<div style="display:flex;flex-direction:column;align-items:' + align + ';margin:4px 0;">' +
        label +
        '<div style="max-width:72%;background:' + bg + ';color:' + color + ';' +
             'padding:8px 12px;border-radius:16px;font-size:13px;word-break:break-word;">' +
          text +
        '</div>' +
        '<div style="font-size:10px;color:#aaa;margin-top:2px;">' + time + '</div>' +
      '</div>'
    );

    scrollToBottom();
  }

  // ── System message ────────────────────────────────────────────────
  function systemMessage(text) {
    appendMessage({ type: "system", message: text });
  }

  // ── Subscribe via existing App.subscribeTopic ─────────────────────
  function connect() {
    // Ensure solution is set on the global App object
    App.setSolution(SOLUTION);

    subscription = App.subscribeTopic(ROOM, function(data) {
      // Ignore typing events — handle separately
      if (data.type === "typing") {
        showTyping(data.sender_name, data.sender_id);
        return;
      }
      appendMessage(data);
    });

    // Patch connected/disconnected to update status badge
    var original = {
      connected:    subscription.consumer.subscriptions.subscriptions[0] && function(){},
      disconnected: function(){}
    };

    var sub = App.topics[SOLUTION + ":" + ROOM];
    if (sub) {
      var _connected    = sub.connected.bind(sub);
      var _disconnected = sub.disconnected.bind(sub);

      sub.connected = function() {
        _connected && _connected();
        $status.html('<i class="fa fa-circle" style="color:#69f0ae;"></i> Connected');
        systemMessage("You joined " + ROOM);
      };
      sub.disconnected = function() {
        _disconnected && _disconnected();
        $status.html('<i class="fa fa-circle" style="color:#ef5350;"></i> Disconnected');
        systemMessage("Connection lost — reconnecting…");
      };
    }
  }

  // ── Typing indicator ──────────────────────────────────────────────
  var typingUsers = {};

  function showTyping(name, id) {
    if (String(id) === String(MY_ID)) return;
    typingUsers[id] = name;
    renderTyping();
    clearTimeout(typingUsers[id + "_timer"]);
    typingUsers[id + "_timer"] = setTimeout(function() {
      delete typingUsers[id];
      delete typingUsers[id + "_timer"];
      renderTyping();
    }, 3000);
  }

  function renderTyping() {
    var names = [];
    $.each(typingUsers, function(id, name) {
      if (!String(id).endsWith("_timer")) names.push(name);
    });
    if (names.length === 0) {
      $typing.text("");
    } else if (names.length === 1) {
      $typing.text(names[0] + " is typing…");
    } else {
      $typing.text(names.length + " people are typing…");
    }
  }

  function sendTyping() {
    if (!subscription) return;
    var sub = App.topics[SOLUTION + ":" + ROOM];
    if (sub) {
      sub.perform("speak", {
        message:     "",
        type:        "typing",
        sender_name: MY_NAME,
        sender_id:   MY_ID
      });
    }
  }

  // ── Send message ──────────────────────────────────────────────────
  function sendMessage() {
    var text = $.trim($input.val());
    if (!text) return;

    var sub = App.topics[SOLUTION + ":" + ROOM];
    if (!sub) {
      systemMessage("Not connected yet — please wait.");
      return;
    }

    // Optimistically render own message immediately
    appendMessage({
      sender_id:   MY_ID,
      sender_name: MY_NAME,
      message:     text,
      time:        new Date().toISOString(),
      type:        "message"
    });

    sub.perform("speak", {
      message:     text,
      type:        "message",
      sender_name: MY_NAME,
      sender_id:   MY_ID
    });

    $input.val("").focus();
  }

  // ── Wire up UI events ─────────────────────────────────────────────
  $send.on("click", sendMessage);

  $input.on("keydown", function(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  $input.on("input", function() {
    if (!isTyping) {
      isTyping = true;
      sendTyping();
    }
    clearTimeout(typingTimer);
    typingTimer = setTimeout(function() { isTyping = false; }, 2000);
  });

  // ── Start ─────────────────────────────────────────────────────────
  $(document).ready(function() {
    connect();
    $input.focus();
  });

})();
</script>
